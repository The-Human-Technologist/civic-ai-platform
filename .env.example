# Copy to .env.local for local development (never commit real secrets)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Working prototype: real authorized-video processing runs in the separate local worker.
AI_PROCESSING_MODE=worker
ALLOW_DEV_JOB_MUTATIONS=false

# Separate worker backend for authorized uploaded-video processing only.
AI_WORKER_URL=http://localhost:8000

# Optional for local review; required for persistent multi-user job storage.
MONGODB_URI=
MONGODB_DB_NAME=civic_ai_platform

# Safe upload + sampling defaults for worker mode.
MAX_VIDEO_UPLOAD_MB=250
FRAME_SAMPLE_RATE_FPS=1
PRIVACY_MASKING_ENABLED=true
MAX_SAMPLED_FRAMES=300
YOLO_MODEL_PATH=models/yolo26n.pt
YOLO_DEVICE=auto
YOLO_IMAGE_SIZE=640
YOLO_CONFIDENCE=0.35
ALLOW_MODEL_DOWNLOAD=false
CONGESTION_VEHICLE_THRESHOLD=5
CONGESTION_PERSON_THRESHOLD=10

# Persistent authorized-footage storage stays disabled by default.
# Direct prototype analysis deletes the clip after worker inference.
# Never commit real footage.
# Prefer private bucket with short-lived signed URLs for controlled pilots.
AUTHORIZED_UPLOADS_ENABLED=false
STORAGE_PROVIDER=disabled
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
MAX_AUTHORIZED_VIDEO_UPLOAD_MB=250
AUTHORIZED_FOOTAGE_RETENTION_DAYS=30

# Existing app settings
# DATABASE_URL=postgresql://user:password@localhost:5432/civic_ai
MAP_PROVIDER=none
# AUTH_SECRET=generate-a-long-random-string-for-production
