# Copy to .env.local for local development (never commit real secrets)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Current public alpha remains mock by default.
AI_PROCESSING_MODE=mock

# Separate worker backend for future authorized uploaded-video processing only.
AI_WORKER_URL=http://localhost:8000

# Optional in public demo; required for persistent pilot-ready job storage.
MONGODB_URI=
MONGODB_DB_NAME=civic_ai_platform

# Safe upload + sampling defaults for planned worker mode.
MAX_VIDEO_UPLOAD_MB=250
FRAME_SAMPLE_RATE_FPS=1
PRIVACY_MASKING_ENABLED=true

# Existing app settings
# DATABASE_URL=postgresql://user:password@localhost:5432/civic_ai
STORAGE_PROVIDER=local
MAP_PROVIDER=none
# AUTH_SECRET=generate-a-long-random-string-for-production
